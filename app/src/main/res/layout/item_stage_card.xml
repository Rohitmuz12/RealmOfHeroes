<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/bg_panel"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/stageNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stage 1: Forest Path"
            android:textColor="@color/text_light"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/stageDescText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enemy description"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/stageRewardText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reward: 30 gold, 25 XP"
            android:textColor="@color/xp_green"
            android:textSize="11sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/stageActionButton"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:text="Fight"
        android:textSize="13sp"
        android:backgroundTint="@color/gold"
        android:textColor="@color/bg_dark"/>

</LinearLayout>
