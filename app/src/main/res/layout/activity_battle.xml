<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <!-- Enemy status panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_panel"
        android:padding="14dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/enemyNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enemy Name"
            android:textColor="@color/text_light"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/enemyStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <ProgressBar
            android:id="@+id/enemyHpBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:max="100"
            android:progress="100"
            android:progressTint="@color/hp_red"/>

        <TextView
            android:id="@+id/enemyHpText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HP: 100/100"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Battle log -->
    <ScrollView
        android:id="@+id/logScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_panel"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/battleLogText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="The battle begins!"
            android:textColor="@color/text_light"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp"/>
    </ScrollView>

    <!-- Player status panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_panel"
        android:padding="14dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/playerNameText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Player Name"
            android:textColor="@color/text_light"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/playerStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginBottom="6dp"/>

        <ProgressBar
            android:id="@+id/playerHpBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:max="100"
            android:progress="100"
            android:progressTint="@color/hp_red"/>

        <TextView
            android:id="@+id/playerHpText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HP: 100/100"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="6dp"/>

        <ProgressBar
            android:id="@+id/playerManaBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:max="100"
            android:progress="100"
            android:progressTint="@color/mana_blue"/>

        <TextView
            android:id="@+id/playerManaText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MP: 50/50"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Skill buttons -->
    <GridLayout
        android:id="@+id/skillGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="1"
        android:rowCount="3">

        <Button
            android:id="@+id/skillButton0"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_columnWeight="1"
            android:text="Skill 1"
            android:textSize="13sp"
            android:backgroundTint="@color/gold"
            android:textColor="@color/bg_dark"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/skillButton1"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_columnWeight="1"
            android:text="Skill 2"
            android:textSize="13sp"
            android:backgroundTint="@color/bg_panel_light"
            android:textColor="@color/text_light"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/skillButton2"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_columnWeight="1"
            android:text="Skill 3"
            android:textSize="13sp"
            android:backgroundTint="@color/bg_panel_light"
            android:textColor="@color/text_light"/>

    </GridLayout>

</LinearLayout>
