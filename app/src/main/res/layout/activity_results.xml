<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="32dp"
    android:gravity="center">

    <TextView
        android:id="@+id/resultTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VICTORY"
        android:textColor="@color/gold"
        android:textSize="30sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:id="@+id/rewardsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_panel"
        android:padding="20dp"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/currencyEarnedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+30 Gold"
            android:textColor="@color/gold"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/xpEarnedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+25 XP"
            android:textColor="@color/xp_green"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/levelUpText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Level Up!"
            android:textColor="@color/mana_blue"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"/>
    </LinearLayout>

    <Button
        android:id="@+id/continueButton"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:text="Continue"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/gold"
        android:textColor="@color/bg_dark"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/menuButton"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:text="Main Menu"
        android:textSize="16sp"
        android:backgroundTint="@color/bg_panel_light"
        android:textColor="@color/text_light"/>

</LinearLayout>
